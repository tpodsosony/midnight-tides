            title="Toll the Hounds"
            author="Steven Erikson"
            rating="★★★★★"
            genre="Fantasy"
            image="https://m.media-amazon.com/images/S/compressed.photo.goodreads.com/books/1442456749i/938544.jpg"
            link='blog/tollthehoundsreflection/'
        />

        <LogCard
            title="The New York Trilogy"
            author="Paul Auster"
            rating="★★★★⯪"

<style>
    .log {
        display: flex;
        flex-wrap: wrap;
        gap: 2em;
        margin: auto;
        justify-content: center;
    }

    @media only screen and (max-width: 750px) {
        .log {
            flex-direction: column;
            gap: 1em;
        }
    }
</style>

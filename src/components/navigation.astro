---
const { pathname } = Astro.url;
---

<div class="nav-links">
    <ul>
        <li><a class={pathname.slice(1) === '' ? 'active' : ''} href="/">Home</a></li>
        <li><a class={pathname.includes('blog/') ? 'active' : ''} href="/blog/1">Blog</a></li>
        <li><a class={pathname.slice(1) === 'interests/' ? 'active' : ''} href="/interests/">Interests</a></li>
        <li><a class={pathname.slice(1) === 'now/' ? 'active' : ''} href="/now/">Now</a></li>
    </ul>
    
</div>

<style>
    .active{
        background-color: rgb(34, 38, 87);
        border-radius: 10px;
        border:solid;
    }
    .nav-links{
        padding: 6px 8px 6px 16px;
        text-decoration: none;
        font-size: 18px;
        display: block;
		
    }

    .nav-links ul{
        list-style-type: none;
        margin: 0px;
        padding: 1px;
        line-height: 40px;
    }

    @media only screen and (max-width: 1000000px) {
        .nav-links{
            display: flex;
            flex-direction: column;
            margin: auto;
        }

        .nav-links li{
            display: inline;
            padding-right: 1em;
        }
    }
</style>